    <string name="perm_install_desc">Allow Rookie On Quest to install game files (APK) directly on your headset.</string>
    <string name="perm_storage_desc">Allow access to manage all files for game data. This is required to copy OBB files to the correct location.</string>
    <string name="perm_battery_desc">Allow Rookie On Quest to run in the background without battery restrictions. This prevents interruptions during long downloads.</string>
    
    <string name="perm_install_why">Why: Quest headsets require special permission to install APK files from outside the official store.</string>
    <string name="perm_storage_why">Why: Many VR games require OBB data files that must be copied to a specific system folder.</string>
    <string name="perm_battery_why">Why: Large game downloads can take 30+ minutes. Battery optimization may pause downloads unexpectedly.</string>
    
